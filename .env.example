# =============================================================================
# INFRASTRUCTURE
# =============================================================================

# Domain & SSL
DOMAIN=example.com
PUBLIC_DOMAIN=example.com
ACME_EMAIL=admin@example.com

# Traefik Dashboard Auth (generate with: htpasswd -nb admin password)
# Note: escape $ as $$ in docker-compose
TRAEFIK_AUTH=admin:$$apr1$$changeme

# Cloudflare DNS Challenge (for Let's Encrypt wildcard certs)
CF_DNS_API_TOKEN=your-cloudflare-dns-api-token

# =============================================================================
# DATABASES
# =============================================================================

# PostgreSQL (backend application database)
POSTGRES_DB=mchost
POSTGRES_USER=mchost
POSTGRES_PASSWORD=changeme

# MySQL/MariaDB (Pterodactyl panel database)
MYSQL_ROOT_PASSWORD=changeme
MYSQL_DATABASE=panel
MYSQL_USER=pterodactyl
MYSQL_PASSWORD=changeme

# =============================================================================
# MONITORING
# =============================================================================

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# Sentry (error tracking)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# =============================================================================
# PTERODACTYL PANEL
# =============================================================================

# Panel Configuration (for the Pterodactyl container itself)
PTERODACTYL_URL=https://panel.example.com
PTERODACTYL_TIMEZONE=UTC
PTERODACTYL_EMAIL=admin@example.com

# Panel API Access (for backend to communicate with panel)
PANEL_SECRET_KEY=ptla_your-application-api-key
PANEL_ADMIN_CLIENT_SECRET_KEY=ptlc_your-client-api-key
PANEL_ADMIN_USER=admin
PANEL_ADMIN_PASSWORD=changeme

# =============================================================================
# EXTERNAL APIS
# =============================================================================

# Cloudflare API (for origin certificates, DNS management)
CLOUDFLARE_SECRET_KEY=your-cloudflare-api-key
CLOUDFLARE_ORIGIN_CERTIFICATE=your-origin-certificate
CLOUDFLARE_CERTIFICATE_PRIVATE_KEY=your-certificate-private-key

# Hetzner Cloud API
HETZNER_SECRET_KEY=your-hetzner-api-token

# Stripe (payments)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_SECRET_SIGNING_KEY=whsec_your-webhook-signing-secret

# Clerk (authentication)
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key
CLERK_SECRET_SIGNING_KEY=your-clerk-webhook-signing-key
JWT_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json

# =============================================================================
# APPLICATION
# =============================================================================

# Environment
ENV=production

# Domains (used by backend for URL generation)
CLOUD_DOMAIN=example.com
INFRA_DOMAIN=infra.example.com

# Shared encryption key (used by both backend and frontend for password encryption)
PASSWORD_KEY=base64-encoded-32-byte-key

# SSH Keys (for server provisioning)
SSH_PRIVATE_KEY=your-ssh-private-key
SSH_PUBLIC_KEY=your-ssh-public-key

# =============================================================================
# FRONTEND (build-time variables)
# =============================================================================

# These are baked into the Next.js bundle at build time
NEXT_PUBLIC_API_URL=https://example.com/api
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key
